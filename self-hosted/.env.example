# MyPasswordChecker.com Self-Hosted Configuration
# Copy this file to .env and update with your values

# Application
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Security
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING_IN_PRODUCTION
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database
DATABASE_URL=postgresql://postgres:password@postgres:5432/mypasswordchecker
POSTGRES_PASSWORD=CHANGE_THIS_IN_PRODUCTION

# Redis
REDIS_URL=redis://:redispassword@redis:6379
REDIS_PASSWORD=CHANGE_THIS_IN_PRODUCTION

# Stripe (optional - for payment processing)
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring (optional)
SENTRY_DSN=
DATADOG_API_KEY=

# Domain
DOMAIN=https://yourdomain.com
