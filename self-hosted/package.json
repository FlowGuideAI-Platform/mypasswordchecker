{
  "name": "@mypasswordchecker/self-hosted",
  "version": "1.0.0",
  "description": "Self-hosted MyPasswordChecker.com - SOC 2 Type 2 compliant password strength API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "docker:build": "docker build -t mypasswordchecker/self-hosted:latest .",
    "docker:run": "docker-compose up",
    "k8s:deploy": "kubectl apply -f k8s/",
    "terraform:init": "cd terraform && terraform init",
    "terraform:plan": "cd terraform && terraform plan",
    "terraform:apply": "cd terraform && terraform apply"
  },
  "keywords": [
    "password",
    "security",
    "zxcvbn",
    "quantum",
    "soc2",
    "compliance"
  ],
  "author": "MyPasswordChecker.com",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "uuid": "^9.0.1",
    "pino": "^8.17.2",
    "pino-http": "^9.0.0",
    "dotenv": "^16.3.1",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "stripe": "^14.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
